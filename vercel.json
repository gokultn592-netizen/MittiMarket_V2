{
  "version": 2,
  "rewrites": [
    { "source": "/auth/(.*)", "destination": "/api/index.js" },
    { "source": "/products(.*)", "destination": "/api/index.js" },
    { "source": "/orders(.*)", "destination": "/api/index.js" },
    { "source": "/farmers(.*)", "destination": "/api/index.js" },
    { "source": "/admin/orders", "destination": "/api/index.js" },
    { "source": "/admin", "destination": "/public/admin.html" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ],
  "cleanUrls": true
}
