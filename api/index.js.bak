const express = require('express');
const cors = require('cors');
const path = require('path');
const fs = require('fs');
const mongoose = require('mongoose');
const http = require('http');
const { Server } = require('socket.io');

const app = express();
const server = http.createServer(app);
const io = new Server(server, { cors: { origin: "*" } });
const port = process.env.PORT || 8080;

app.use(cors());
app.use(express.json({ limit: '50mb' }));
app.use(express.static(path.join(__dirname, '..', 'public')));

// Explicit route for debugging/serving the root React/HTML app
app.get('/', (req, res) => {
    const indexPath = path.join(__dirname, '..', 'public', 'index.html');
    if (fs.existsSync(indexPath)) res.sendFile(indexPath);
    else res.status(404).send("<h2>MittiMart API is Live!</h2><p>Wait! The 'public' directory containing index.html was not found.</p>");
});

// Schemas
const productSchema = new mongoose.Schema({
    id: { type: Number, unique: true }, // For frontend compatibility
    name: String,
    description: String,
    category: String,
    tags: [String],
    image_url: String, // Maps to 'img' in JSON
    image_query: String,
    stock: { type: Number, default: 0 },
    price: { type: Number, default: 0 },
    unit: String,     // e.g. "1 kg", "500 ml"
    rating: { type: Number, default: 5.0 },
    reviews: { type: Number, default: 0 },
    farmerId: { type: mongoose.Schema.Types.ObjectId, ref: 'Farmer' },
    created_at: { type: Date, default: Date.now }
});
const Product = mongoose.model('Product', productSchema);

const orderSchema = new mongoose.Schema({
    buyerId: String,
    buyerName: String,
    buyerLoc: { lat: Number, lon: Number },
    sellerLoc: { lat: Number, lon: Number },
    items: [Object],
    total: Number,
    eta: Number,
    status: { type: String, default: "pending" },
    riderId: String,
    created_at: { type: Date, default: Date.now }
});
const Order = mongoose.model('Order', orderSchema);

const userSchema = new mongoose.Schema({
    name: { type: String, required: true },
    phone: { type: String, required: true, unique: true },
    password: { type: String, required: true },
    role: { type: String, default: 'buyer' },
    lat: Number,
    lon: Number,
    cart: { type: [Object], default: [] },
    wishlist: { type: [Number], default: [] },
    created_at: { type: Date, default: Date.now }
});
const User = mongoose.model('User', userSchema);

const farmerSchema = new mongoose.Schema({
    name: { type: String, required: true },
    address: {
        village: String,
        district: String,
        state: String
    },
    location: {
        type: { type: String, default: "Point" },
        coordinates: { type: [Number], index: '2dsphere' } // [longitude, latitude]
    },
    experience: { type: Number, default: 0 },
    experienceLevel: String, // Beginner, Intermediate, Top Farmer
    products: [{ type: mongoose.Schema.Types.ObjectId, ref: 'Product' }],
    rating: { type: Number, default: 0 },
    qualityStatus: { type: String, enum: ['Pending', 'Verified', 'Rejected'], default: 'Pending' },
    qualityReview: String,
    farmerId: { type: String, unique: true, sparse: true },
    totalOrders: { type: Number, default: 0 },
    isDistrictHead: { type: Boolean, default: false },
    userId: { type: mongoose.Schema.Types.ObjectId, ref: 'User' },
    created_at: { type: Date, default: Date.now }
});

// Auto-calculate experienceLevel
farmerSchema.pre('save', function(next) {
    calculateExperienceLevel(this);
    next();
});

farmerSchema.pre('findOneAndUpdate', function(next) {
    const update = this.getUpdate();
    if (update.experience !== undefined) {
        if (update.experience <= 2) update.experienceLevel = "Beginner";
        else if (update.experience <= 7) update.experienceLevel = "Intermediate";
        else update.experienceLevel = "Top Farmer";
    }
    next();
});

function calculateExperienceLevel(doc) {
    if (doc.experience <= 2) doc.experienceLevel = "Beginner";
    else if (doc.experience <= 7) doc.experienceLevel = "Intermediate";
    else doc.experienceLevel = "Top Farmer";
}

const Farmer = mongoose.model('Farmer', farmerSchema);

// Legacy Mock DB (Deprecated - Now moved to MongoDB Atlas)
let legacyDb = { users: [], carts: {}, wishlists: {}, nextUserId: 1001 };

// ============================================
// IMAGE & VALIDATION LOGIC
// ============================================
function generateImageQuery(productBody) {
    const name = productBody.name || "";
    const tags = productBody.tags || [];
    const materials = ["clay", "brass", "wood", "palm leaf", "cotton"];
    
    let materialStr = "";
    for (const t of tags) {
        if (materials.includes(t.toLowerCase())) materialStr = t;
    }
    
    const context = tags.includes("temple") ? "temple" : (tags.includes("kitchen") ? "village kitchen" : "village styled");
    return `authentic traditional Tamil Nadu ${materialStr} ${name} ${context}`.trim();
}

function validateImage(product, metadataContext = "") {
    let flag = "valid";
    if (!product.image_url) {
        flag = "missing";
    } else {
        const queryMetadataLower = (product.image_query + " " + metadataContext).toLowerCase();
        let matchCount = 0;
        const tags = product.tags || [];
        tags.forEach(tag => {
            if (queryMetadataLower.includes(tag.toLowerCase())) matchCount++;
        });
        if (tags.length > 0 && matchCount === 0) flag = "invalid";
    }
    return flag;
}

// ============================================
// REAL-TIME ADMIN DASHBOARD (WebSockets)
// ============================================
io.on('connection', (socket) => {
    console.log("Monitor/Admin connected:", socket.id);
});

function emitAdminAlert(type, message, data) {
    io.emit('admin_alert', { type, message, data, timestamp: new Date() });
}

// ============================================
// REST API ROUTES
// ============================================

// --- Products (MongoDB) ---
app.get('/api/products', async (req, res) => {
    try {
        const products = await Product.find({});
        // Map image_url back to img for frontend compatibility
        const remapped = products.map(p => {
            const obj = p.toObject();
            obj.img = obj.image_url;
            return obj;
        });
        res.json(remapped);
    } catch(err) { res.status(500).json({ error: err.message }); }
});

app.post('/api/products', async (req, res) => {
    try {
        const newProdData = {
            id: req.body.id || Math.floor(1000 + Math.random() * 9000),
            name: req.body.name,
            description: req.body.description,
            category: req.body.category,
            tags: req.body.tags || [],
            image_url: req.body.img || req.body.image_url,
            stock: req.body.stock || 0,
            price: req.body.price || 0,
            unit: req.body.unit || "unit",
            farmerId: req.body.farmerId
        };
        // 1. Generate Query
        newProdData.image_query = generateImageQuery(newProdData);
        
        // 2. Validate logic
        const validFlag = validateImage(newProdData, "");
        if (validFlag === "missing") emitAdminAlert("Missing Product Image", `Product ${newProdData.name} has no image.`, newProdData);
        if (validFlag === "invalid") emitAdminAlert("Mismatched Image", `Product ${newProdData.name} image might be misrepresenting the real product.`, newProdData);

        const prod = new Product(newProdData);
        await prod.save();
        
        // Return object with 'img' field for frontend compatibility
        const responseObj = prod.toObject();
        responseObj.img = responseObj.image_url;

        io.emit('product_added', responseObj); // Live product preview
        res.status(201).json(responseObj);
    } catch(err) { res.status(500).json({ error: err.message }); }
});

app.put('/api/products/:id', async (req, res) => {
    try {
        const prod = await Product.findByIdAndUpdate(req.params.id, req.body, { new: true });
        if(!prod) return res.status(404).json({error: "Not found"});
        
        // Alert if low stock
        if (prod.stock < 5) emitAdminAlert("Low Stock", `Product ${prod.name} has low stock (${prod.stock}).`, prod);
        
        io.emit('product_updated', prod);
        res.json(prod);
    } catch(err) { res.status(500).json({ error: err.message }); }
});

app.delete('/api/products/:id', async (req, res) => {
    try {
        await Product.findByIdAndDelete(req.params.id);
        io.emit('product_deleted', req.params.id);
        res.json({success: true});
    } catch(err) { res.status(500).json({ error: err.message }); }
});

// --- Orders (MongoDB) ---
app.get('/api/orders', async (req, res) => {
    try {
        const orders = await Order.find({});
        res.json(orders);
    } catch(err) { res.status(500).json({ error: err.message }); }
});

app.post('/api/orders', async (req, res) => {
    try {
        const newOrder = new Order(req.body);
        await newOrder.save();
        io.emit('new_order', newOrder); // Real-time Order Tracking
        res.status(201).json(newOrder);
    } catch(err) { res.status(500).json({ error: err.message }); }
});

app.put('/api/orders/:id/status', async (req, res) => {
    try {
        const { status } = req.body;
        const order = await Order.findByIdAndUpdate(req.params.id, { status }, { new: true });
        if(!order) return res.status(404).json({error: "Not found"});
        
        // If delivered, update farmer stats
        if (status === 'completed' || status === 'delivered') {
            await updateFarmerStatsFromOrder(order);
        }

        io.emit('order_status_update', order);
        res.json(order);
    } catch(err) { res.status(500).json({ error: err.message }); }
});


// --- Auth (MongoDB) ---
app.post('/api/auth/register', async (req, res) => {
    try {
        const { name, phone, password, role, lat, lon, village, district, state } = req.body;
        if(await User.findOne({ phone })) return res.status(400).json({ error: "Phone already registered" });
        
        const user = new User({ name, phone, password, role, lat, lon });
        await user.save();

        // If seller, create a Farmer profile
        if (role === 'seller') {
            const farmer = new Farmer({
                name,
                userId: user._id,
                address: {
                    village: village || "",
                    district: district || "",
                    state: state || "Tamil Nadu"
                },
                location: {
                    type: "Point",
                    coordinates: [lon || 0, lat || 0]
                },
                qualityStatus: 'Pending'
            });
            await farmer.save();
        }

        io.emit('user_activity', { action: "register", user: user.name });
        res.status(201).json({ user });
    } catch(err) { res.status(500).json({ error: err.message }); }
});

app.post('/api/auth/login', async (req, res) => {
    try {
        const { phone, password } = req.body;
        const user = await User.findOne({ phone, password });
        if (!user) return res.status(401).json({ error: "Invalid credentials" });
        io.emit('user_activity', { action: "login", user: user.name });
        res.json({ user });
    } catch(err) { res.status(500).json({ error: err.message }); }
});

// --- Unified DB Fetch (For Frontend app.js) ---
app.get('/api/db', async (req, res) => {
    try {
        const products = await Product.find({});
        const users = await User.find({});
        const orders = await Order.find({});
        
        // Map image_url back to img for frontend compatibility
        const remappedProducts = products.map(p => {
            const obj = p.toObject();
            obj.img = obj.image_url;
            return obj;
        });

        // Structure data exactly as frontend db expects
        const resDb = {
            products: remappedProducts,
            users: users,
            orders: orders,
            carts: {},
            wishlists: {},
            nextOrderId: orders.length + 1001,
            nextProductId: products.length + 100,
            nextUserId: users.length + 501
        };
        
        // Re-map carts and wishlists from user profiles
        users.forEach(u => {
            if (u.cart) resDb.carts[u.id || u._id] = u.cart;
            if (u.wishlist) resDb.wishlists[u.id || u._id] = u.wishlist;
        });
        
        res.json(resDb);
    } catch(err) { res.status(500).json({ error: err.message }); }
});

// --- Unified SYNC (For Frontend updates) ---
app.post('/api/sync', async (req, res) => {
    try {
        const incomingDb = req.body;
        
        // Update Users (Carts/Wishlists only for performance, or specific fields)
        if (incomingDb.users) {
            for (const u of incomingDb.users) {
                const userCart = incomingDb.carts[u.id] || [];
                const userWish = incomingDb.wishlists[u.id] || [];
                await User.findOneAndUpdate({ phone: u.phone }, { cart: userCart, wishlist: userWish });
            }
        }
        res.json({ success: true });
    } catch(err) { res.status(500).json({ error: err.message }); }
});

// Analytics Hook (Example endpoint for Admin Dashboard Analytics Data)
app.get('/api/analytics', async (req, res) => {
    const orders = await Order.find({});
    let totalSales = 0;
    orders.forEach(o => totalSales += (o.total_price || 0));
    res.json({ salesTrends: totalSales, totalOrders: orders.length });
});

// ============================================
// FARMER COMMUNITY HUB APIS
// ============================================

// --- Admin APIs ---

// 1. Get all farmers
app.get('/api/admin/farmers', async (req, res) => {
    try {
        const farmers = await Farmer.find({}).populate('products');
        res.json(farmers);
    } catch(err) { res.status(500).json({ error: err.message }); }
});

// 2. Approve / Reject farmers
app.patch('/api/admin/farmers/:id/verify', async (req, res) => {
    try {
        const { status, review } = req.body;
        if (!['Verified', 'Rejected'].includes(status)) return res.status(400).json({ error: "Invalid status" });

        const farmer = await Farmer.findById(req.params.id);
        if (!farmer) return res.status(404).json({ error: "Farmer not found" });

        farmer.qualityStatus = status;
        farmer.qualityReview = review || farmer.qualityReview;

        if (status === 'Verified' && !farmer.farmerId) {
            // Generate unique farmerId: MM-F-RANDOM
            farmer.farmerId = `MM-F-${Math.floor(1000 + Math.random() * 9000)}`;
        }

        await farmer.save();
        
        // Trigger District Head update for this farmer's district
        await updateDistrictHead(farmer.address.district);

        res.json({ message: `Farmer ${status}`, farmer });
    } catch(err) { res.status(500).json({ error: err.message }); }
});

// 3. Edit farmer details
app.put('/api/admin/farmers/:id', async (req, res) => {
    try {
        const farmer = await Farmer.findByIdAndUpdate(req.params.id, req.body, { new: true });
        if (req.body.address && req.body.address.district) {
            await updateDistrictHead(req.body.address.district);
        }
        res.json(farmer);
    } catch(err) { res.status(500).json({ error: err.message }); }
});

// 4. View farmer products
app.get('/api/admin/farmers/:id/products', async (req, res) => {
    try {
        const farmer = await Farmer.findById(req.params.id).populate('products');
        if (!farmer) return res.status(404).json({ error: "Farmer not found" });
        res.json(farmer.products);
    } catch(err) { res.status(500).json({ error: err.message }); }
});

// 5. Update district heads manually
app.post('/api/admin/districts/recalculate', async (req, res) => {
    try {
        const districts = await Farmer.distinct('address.district');
        for (const d of districts) {
            await updateDistrictHead(d);
        }
        res.json({ success: true, message: "District heads recalculated" });
    } catch(err) { res.status(500).json({ error: err.message }); }
});

// --- Public APIs ---

// 1. Get all verified farmers
app.get('/api/farmers', async (req, res) => {
    try {
        const farmers = await Farmer.find({ qualityStatus: 'Verified' }).populate('products');
        res.json(farmers);
    } catch(err) { res.status(500).json({ error: err.message }); }
});

// 2. Get nearest farmers
app.get('/api/farmers/nearby', async (req, res) => {
    try {
        const { lat, lon } = req.query;
        if (!lat || !lon) return res.status(400).json({ error: "Latitude and Longitude required" });

        const farmers = await Farmer.find({
            qualityStatus: 'Verified',
            location: {
                $near: {
                    $geometry: { type: "Point", coordinates: [parseFloat(lon), parseFloat(lat)] },
                }
            }
        }).populate('products');
        res.json(farmers);
    } catch(err) { res.status(500).json({ error: err.message }); }
});

// 3. Get farmers by product
app.get('/api/farmers/by-product/:productId', async (req, res) => {
    try {
        const farmers = await Farmer.find({
            qualityStatus: 'Verified',
            products: req.params.productId
        }).populate('products');
        res.json(farmers);
    } catch(err) { res.status(500).json({ error: err.message }); }
});

// 4. Get farmers sorted by experience
app.get('/api/farmers/sorted', async (req, res) => {
    try {
        const { experienceLevel } = req.query;
        let query = { qualityStatus: 'Verified' };
        if (experienceLevel) query.experienceLevel = experienceLevel;

        const farmers = await Farmer.find(query).sort({ experience: -1 }).populate('products');
        res.json(farmers);
    } catch(err) { res.status(500).json({ error: err.message }); }
});

// 5. Search farmers by name and district
app.get('/api/farmers/search', async (req, res) => {
    try {
        const { name, district } = req.query;
        let query = { qualityStatus: 'Verified' };
        
        if (name) {
            query.name = { $regex: name, $options: 'i' }; // Case-insensitive partial match
        }
        if (district) {
            query['address.district'] = { $regex: district, $options: 'i' };
        }

        // Return curated fields for peer-to-peer discovery
        const farmers = await Farmer.find(query)
            .select('name address experienceLevel rating totalOrders isDistrictHead farmerId')
            .populate('products', 'name category');
            
        res.json(farmers);
    } catch(err) { res.status(500).json({ error: err.message }); }
});

// Helper: Update Farmer stats from completed order
async function updateFarmerStatsFromOrder(order) {
    try {
        // Extract all unique farmer IDs from products in the order
        // Note: For simplicity, we assume each item in the order has a farmerId 
        // or we fetch the product to find the farmerId
        for (const item of order.items) {
            const product = await Product.findById(item._id || item.productId);
            if (product && product.farmerId) {
                await Farmer.findByIdAndUpdate(product.farmerId, {
                    $inc: { totalOrders: 1 }
                });
            }
        }
    } catch (err) {
        console.error("Error updating farmer stats:", err);
    }
}

// Helper: Update District Head logic
async function updateDistrictHead(district) {
    if (!district) return;
    
    // Find all farmers in the district
    const farmers = await Farmer.find({ 'address.district': district, qualityStatus: 'Verified' });
    if (farmers.length === 0) return;

    // Sort by experience descending
    farmers.sort((a, b) => b.experience - a.experience);

    const headId = farmers[0]._id;

    // Update all farmers in this district
    await Farmer.updateMany({ 'address.district': district }, { isDistrictHead: false });
    await Farmer.findByIdAndUpdate(headId, { isDistrictHead: true });
}

// ============================================
// DATABASE CONNECTION & SEEDING (Bottom of file)
// ============================================
const MONGODB_URI = process.env.MONGODB_URI || 'mongodb://127.0.0.1:27017/mittimart';

async function seedDatabaseIfEmpty() {
    try {
        const count = await Product.countDocuments();
        if (count === 0) {
            console.log("MongoDB is empty. Seeding from database.json...");
            const dbPath = path.join(__dirname, '..', 'database.json');
            if (fs.existsSync(dbPath)) {
                const data = JSON.parse(fs.readFileSync(dbPath, 'utf8'));
                if (data.products && data.products.length > 0) {
                    const productsToSeed = data.products.map(p => ({
                        ...p,
                        image_url: p.img // Map legacy img to new image_url
                    }));
                    await Product.insertMany(productsToSeed);
                    console.log(`Successfully seeded ${productsToSeed.length} products.`);
                }
            }
        }
    } catch (err) {
        console.error("Seeding Error:", err);
    }
}

mongoose.connect(MONGODB_URI)
    .then(() => {
        console.log("Connected to MongoDB via " + (process.env.MONGODB_URI ? "Cloud" : "Local"));
        seedDatabaseIfEmpty();
    })
    .catch(err => console.error("MongoDB ERROR:", err));

// EXPORT for Vercel Serverless
module.exports = app;

// START (Only if not running on Vercel)
if (process.env.NODE_ENV !== 'production') {
    server.listen(port, () => {
        console.log(`MittiMart Backend (Mongo+WebSockets) running on port ${port}`);
    });
}
